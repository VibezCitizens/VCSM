      "crossLinks": ["SECURITY_ENGINEERING_CONTRACT", "SINGLE_SOURCE_ACTOR_ARCHITECTURE"],
      "rules": {
        "no_mixing": "Auth and authorization must never be mixed in the same feature, controller, DAL, hook, or screen",
        "auth_scope": "Auth may manage: login, logout, registration, password recovery, email verification, session hydration, auth callback",
        "auth_must_not": "Auth must not decide: actor ownership, VPORT management rights, content permissions, dashboard access",
        "authz_scope": "Authorization may manage: actor ownership checks, VPORT management permission, content access guards, dashboard access, permission gates",
        "authz_must_not": "Authorization must not: check session, verify email, call supabase.auth.*, manage login/logout/registration",
        "controller_violation": "Auth controller checking VPORT ownership is ERROR; authorization controller calling supabase.auth.* is ERROR",
        "dal_violation": "Auth DAL querying vc.actor_owners for permission decisions is HIGH; authorization DAL calling auth APIs is HIGH"
      }

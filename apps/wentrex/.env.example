# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real credentials.

# Supabase
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server
PORT=3000

# Cloudflare R2 storage
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=post-media
# Custom domain bound to the R2 bucket. Leave blank to use the default R2 URL.
R2_PUBLIC_BASE_URL=https://cdn.yourdomain.com

# CORS
ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:5173

# Internal API keys
VITE_COMPRESSOR_API_KEY=your_compressor_api_key
VITE_WEBHOOK_SECRET=your_webhook_secret

# Media processing limits
MAX_DURATION_SEC=30
DEFAULT_MAX_WIDTH=1080
DEFAULT_MAX_HEIGHT=1920

# Feature flags
VITE_VC_PUBLISH_ON_LOGIN=true

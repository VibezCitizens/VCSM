# =============================================================================
# VCSM — Environment Variables
# Copy this file to .env.local and fill in the values for your environment.
# .env.local is gitignored and must never be committed.
# =============================================================================

# Supabase connection (required)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Realm IDs (optional — hardcoded platform defaults apply if omitted)
# Set these if your dev / staging / production databases use different realm UUIDs.
# Realm IDs are embedded into the client bundle at build time (VITE_ prefix).
# They are not secrets — they identify public vs void content partitions.
VITE_PUBLIC_REALM_ID=
VITE_VOID_REALM_ID=

# Sentry error reporting — optional. App runs identically without this.
# Get your DSN from: https://sentry.io → Project Settings → Client Keys (DSN)
# Only active in production builds (enabled: PROD in monitoring.js).
VITE_SENTRY_DSN=

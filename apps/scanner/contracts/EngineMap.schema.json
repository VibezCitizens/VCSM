{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EngineMap",
  "type": "object",
  "required": ["version", "scannerVersion", "generatedAt", "root", "scanDurationMs", "confidence", "engineCount", "data"],
  "properties": {
    "version": { "const": 1 },
    "scannerVersion": { "type": "string" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "root": { "type": "string" },
    "scanDurationMs": { "type": "number" },
    "confidence": { "enum": ["HIGH", "MEDIUM", "LOW", "BLOCKED"] },
    "engineCount": { "type": "number" },
    "data": {
      "type": "object",
      "required": ["engines"],
      "properties": {
        "engines": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["engine", "path", "hasClaude", "exports", "entrypoints", "controllers", "dals", "rpcs", "edgeFunctions", "tests", "confidence"],
            "properties": {
              "engine": { "type": "string" },
              "path": { "type": "string" },
              "hasClaude": { "type": "boolean" },
              "exports": { "type": "number" },
              "entrypoints": { "type": "number" },
              "controllers": { "type": "number" },
              "dals": { "type": "number" },
              "rpcs": { "type": "number" },
              "edgeFunctions": { "type": "number" },
              "tests": { "type": "number" },
              "confidence": { "enum": ["HIGH", "MEDIUM", "LOW", "BLOCKED"] },
              "evidence": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    }
  }
}

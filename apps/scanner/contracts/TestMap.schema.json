{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TestMap",
  "type": "object",
  "required": ["version", "scannerVersion", "generatedAt", "root", "scanDurationMs", "confidence", "testCount", "data"],
  "properties": {
    "version": { "const": 1 },
    "scannerVersion": { "type": "string" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "root": { "type": "string" },
    "scanDurationMs": { "type": "number" },
    "confidence": { "enum": ["HIGH", "MEDIUM", "LOW", "BLOCKED"] },
    "testCount": { "type": "number" },
    "data": {
      "type": "object",
      "required": ["tests", "missingTests"],
      "properties": {
        "tests": { "type": "array" },
        "missingTests": { "type": "array" }
      }
    }
  }
}

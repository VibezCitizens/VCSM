{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FeatureMap",
  "type": "object",
  "required": ["version", "scannerVersion", "generatedAt", "root", "scanDurationMs", "confidence", "featureCount", "data"],
  "properties": {
    "version": { "const": 1 },
    "scannerVersion": { "type": "string" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "root": { "type": "string" },
    "scanDurationMs": { "type": "number" },
    "confidence": { "enum": ["HIGH", "MEDIUM", "LOW", "BLOCKED"] },
    "featureCount": { "type": "number" },
    "data": {
      "type": "object",
      "required": ["features"],
      "properties": {
        "features": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["feature", "kind", "path", "status"],
            "properties": {
              "feature": { "type": "string" },
              "app": { "type": ["string", "null"] },
              "kind": { "type": "string" },
              "path": { "type": "string" },
              "status": { "type": "string" }
            }
          }
        }
      }
    }
  }
}

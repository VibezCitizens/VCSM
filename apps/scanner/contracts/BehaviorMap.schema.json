{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BehaviorMap",
  "type": "object",
  "required": ["version", "scannerVersion", "generatedAt", "root", "data"],
  "properties": {
    "data": {
      "type": "object",
      "required": ["features", "modules", "behaviors"],
      "properties": {
        "features": { "type": "array" },
        "modules": { "type": "array" },
        "behaviors": { "type": "array" }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GovernanceGraph",
  "type": "object",
  "required": ["version", "scannerVersion", "generatedAt", "root", "data"],
  "properties": { "data": { "type": "object", "required": ["nodes", "edges"], "properties": { "nodes": { "type": "array" }, "edges": { "type": "array" } } } }
}

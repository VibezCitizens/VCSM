{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ScreenMap",
  "type": "object",
  "required": ["version", "scannerVersion", "generatedAt", "root", "scanDurationMs", "confidence", "screenCount", "data"],
  "properties": {
    "version": { "const": 1 },
    "scannerVersion": { "type": "string" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "root": { "type": "string" },
    "scanDurationMs": { "type": "number" },
    "confidence": { "enum": ["HIGH", "MEDIUM", "LOW", "BLOCKED"] },
    "screenCount": { "type": "number" },
    "data": {
      "type": "object",
      "required": ["screens"],
      "properties": {
        "screens": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "appId", "feature", "file", "component", "screenKind", "routes", "access", "layer", "confidence", "evidence"],
            "properties": {
              "id": { "type": "string" },
              "appId": { "type": ["string", "null"] },
              "feature": { "type": ["string", "null"] },
              "file": { "type": "string" },
              "component": { "type": "string" },
              "screenKind": { "enum": ["final-screen", "view-screen", "unknown-screen"] },
              "routes": { "type": "array", "items": { "type": "string" } },
              "access": { "type": "string" },
              "layer": { "type": "string" },
              "confidence": { "enum": ["HIGH", "MEDIUM", "LOW", "BLOCKED"] },
              "evidence": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    }
  }
}
